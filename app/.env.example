# Convex URL from `npx convex dev`
VITE_CONVEX_URL=

# WorkOS AuthKit (written automatically when running `npx convex dev` with credentials)
VITE_WORKOS_CLIENT_ID=
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/callback

# Used by Convex CLI during `npx convex dev` for AuthKit auto-provisioning
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
